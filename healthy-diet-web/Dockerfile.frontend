# === 第一階段：編譯 React 程式碼 ===
FROM node:18-alpine AS build
WORKDIR /app

# 安裝依賴
COPY package*.json ./
RUN npm install

# 複製原始碼並編譯 (打包出 dist 資料夾)
COPY . .
RUN npm run build

# === 第二階段：使用 Nginx 運行 ===
FROM nginx:alpine

# 覆蓋 Nginx 預設設定檔
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 將第一階段打包好的網頁放到 Nginx 的目錄中
COPY --from=build /app/dist /usr/share/nginx/html

# 暴露 80 port
EXPOSE 80

# 啟動 Nginx
CMD ["nginx", "-g", "daemon off;"]
